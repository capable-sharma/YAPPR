VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

VITE_APP_URL=https://your-production-domain.com

# ─── AI — Required for AI Coach to work ─────────────────────
# Primary: Get your free key at https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key

# Fallback (optional but recommended): Get free key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# Optional — only needed for Google OAuth login
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Server Environment (development or production)
NODE_ENV=production
